#!/usr/bin/env bash
# Convenience launcher for running r510-command-center directly from a
# checked-out repository, without installing it first.
#
# For a permanent install with a `command-center` command on PATH, use
# install.sh instead.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="${SCRIPT_DIR}${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m command_center.app "$@"
